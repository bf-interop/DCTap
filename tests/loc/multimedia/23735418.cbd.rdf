    </bf:title>
    <bf:title>
      <bf:VariantTitle>
	<bf:note>
	  <bf:Note>
	    <rdfs:label>By the People transcription campaign title</rdfs:label>
	  </bf:Note>
	</bf:note>
	<bf:mainTitle>The Blackwells: an extraordinary family</bf:mainTitle>
      </bf:VariantTitle>
    </bf:title>
    <bf:content>
      <bf:Content rdf:about="http://id.loc.gov/vocabulary/contentTypes/txt">
	<rdfs:label>text</rdfs:label>
	<bf:code>txt</bf:code>
      </bf:Content>
