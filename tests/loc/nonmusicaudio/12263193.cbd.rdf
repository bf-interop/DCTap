    <bf:title>
      <bf:Title>
	<bf:mainTitle>Adventures in Negro history</bf:mainTitle>
      </bf:Title>
    </bf:title>
    <bf:content>
      <bf:Content rdf:about="http://id.loc.gov/vocabulary/contentTypes/spw">
	<rdfs:label>spoken word</rdfs:label>
	<bf:code>spw</bf:code>
      </bf:Content>
    </bf:content>
    <bf:note>
      <bf:Note>
	<rdf:type rdf:resource="http://id.loc.gov/vocabulary/mnotetype/participants"/>
	<rdfs:label>Cast: Jerry Blocker, producer-narrator ; with Burniece Avery, Jiam Desjardins, Carl L. Porter, Max Richards, Florence Pate Sampson, Damon L. White.</rdfs:label>
      </bf:Note>
    </bf:note>
    <bf:summary>
      <bf:Summary>
	<rdfs:label>Vol I. Traces the history of the Negro in the United States from pre-colonial days to the present, and reviews his contribution to the nation in art, politics, industry, education, and the armed forces.</rdfs:label>
      </bf:Summary>
    </bf:summary>
    <bf:tableOfContents>
      <bf:TableOfContents>
	<rdfs:label>Vol. I. Adventures in Negro history -- Vol. II. The Frederick Douglas Years, 1817-1895 -- Vol. III. The Afro-American's quest for education: A black odyssey.</rdfs:label>
      </bf:TableOfContents>
    </bf:tableOfContents>
