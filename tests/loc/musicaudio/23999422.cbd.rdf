	<rdf:type rdf:resource="http://id.loc.gov/vocabulary/mnotetype/participants"/>
	<rdfs:label>Performed by Bruce BecVar, guitar, keyboard, dumbek, percussion, bass, drums, shakti harp, recorder flute ; featuring special guest musicians Charlie Bisharat, Brian BecVar, Steve Reid, Anugama ; with additional accompanying musicians.</rdfs:label>
      </bf:Note>
