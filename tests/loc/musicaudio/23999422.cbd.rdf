    <bf:tableOfContents>
      <bf:TableOfContents>
	<rdfs:label>Jacarandigo -- Seventh heaven -- Caminata flamenco -- Time dreams -- Spinning the light fantastic -- Love knows no bounds -- Sands of time -- Noche pintada -- Flamenco highlife -- Jamaicadoo -- Razamataz -- Song for Jenna -- Forever in my heart -- Shaktipat -- Waves -- Secrets from afar.</rdfs:label>
      </bf:TableOfContents>
    </bf:tableOfContents>
    <bf:note>
