    <bf:tableOfContents>
      <bf:TableOfContents>
	<rdfs:label>Boyo -- The coffee connection -- Soul searcher -- Lucy -- Tiny machines -- Sharp teeth -- Texas size -- Zombie song -- Desert gold -- Captain Future -- Theme from Foster's ghost -- Just enough -- Salad days -- Any which way.</rdfs:label>
      </bf:TableOfContents>
    </bf:tableOfContents>
