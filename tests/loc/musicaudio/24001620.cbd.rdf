    <bf:tableOfContents>
      <bf:TableOfContents>
	<rdfs:label>I should care / S. Cahn ; P. Weston ; A. Stordahl (5:09) -- Betcha by golly wow / L. Creed ; T. Bell (8:35) -- You stepped out of a dream / N. Brown ; G. Kahn (5:51) -- Ann's mood / D. Hazeltine (5:35) -- Pentimento / D. Hazeltine (6:25) -- Four flights up / D. Hazeltine (6:49) -- Every time we say goodbye / C. Porter (9:28) -- Air conditioning / C. Parker (5:43) -- Confluence / D. Hazeltine (6:43).</rdfs:label>
      </bf:TableOfContents>
    </bf:tableOfContents>
