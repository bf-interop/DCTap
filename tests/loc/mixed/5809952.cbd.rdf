    <bf:title>
      <bf:Title>
	<bf:mainTitle>United States. Senate. Committee on the Judiciary. Subcommittee to Investigate Individuals Representing the Interests of Foreign Governments records</bf:mainTitle>
      </bf:Title>
    </bf:title>
    <bf:collectionArrangement>
      <bf:CollectionArrangement>
	<bf:collectionOrganization>Arranged as received, mostly according to the dates of testimony between Aug. 12 and Oct. 2, 1980.</bf:collectionOrganization>
      </bf:CollectionArrangement>
    </bf:collectionArrangement>
    <bf:summary>
      <bf:Summary>
	<rdfs:label>Depositions and testimony of hearings held by the Subcommittee to Investigate the Activities of Individuals Representing the Interests of Foreign Governments relating to transactions between Billy Carter, brother of President Jimmy Carter, and his business dealings with Libya. Includes depositions by Billy Carter, Lloyd N. Cutler, Hamilton Jordan, Bert Lance, Hamilton Jordan, and Jody Powell.</rdfs:label>
      </bf:Summary>
    </bf:summary>
    <bf:note>
      <bf:Note>
	<rdf:type rdf:resource="http://id.loc.gov/vocabulary/mnotetype/lang"/>
	<rdfs:label>Collection material in English.</rdfs:label>
      </bf:Note>
    </bf:note>
