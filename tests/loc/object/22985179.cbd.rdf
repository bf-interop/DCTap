    <bf:title>
      <bf:Title>
	<bf:mainTitle>[Abraham Lincoln 1864 presidential campaign token]</bf:mainTitle>
      </bf:Title>
    </bf:title>
    <bf:content>
      <bf:Content rdf:about="http://id.loc.gov/vocabulary/contentTypes/tdf">
	<rdfs:label>three-dimensional form</rdfs:label>
	<bf:code>tdf</bf:code>
      </bf:Content>
    </bf:content>
    <bf:summary>
      <bf:Summary>
	<rdfs:label>Abraham Lincoln campaign token shows a profile portrait of Abraham Lincoln with the text "The right man in the right place 1864" on the front and laurel leaves and American flag shield with the text "Freedom" on the back. Token belonged to nurse Rebecca Pomroy, who worked at Columbian Hospital, Washington, D.C. during the Civil War.</rdfs:label>
      </bf:Summary>
    </bf:summary>
    <bf:note>
      <bf:Note>
	<rdf:type rdf:resource="http://id.loc.gov/vocabulary/mnotetype/relnote"/>
	<rdfs:label>Forms part of: Liljenquist Family Collection of Civil War Photographs (Library of Congress).</rdfs:label>
      </bf:Note>
    </bf:note>
