    <bf:tableOfContents>
      <bf:TableOfContents>
	<rdfs:label>Cassette. 1. Daurah-yi Afg̲h̲ānistān ke tās̲s̲urāt, 25-04-01 -- Cassette. 2. Qāʼid-i Aʻẓam kā taṣavar-i Pākistān 18-08-00 -- Cassette. 3.Tajdīd-i k̲h̲ilāfat kī pahlī aur ak̲h̲irī kaṛī, 22-07-01 -- Cassette. 4. Islām aur Pākistān, Cauburjī Grāʼūnḍ -- Cassette. 5. Islām men̲ jāgīrdārī aur g̲h̲air ḥāz̤ir zamīndārī.</rdfs:label>
      </bf:TableOfContents>
    </bf:tableOfContents>
    <bf:note>
      <bf:Note>
	<rdf:type rdf:resource="http://id.loc.gov/vocabulary/mnotetype/participants"/>
	<rdfs:label>Lecture: Asrar Ahmad.</rdfs:label>
      </bf:Note>
    </bf:note>
    <bf:summary>
      <bf:Summary>
	<rdfs:label>Collected speeches chiefly on Islamic government systems with special reference to Pakistan.</rdfs:label>
      </bf:Summary>
    </bf:summary>
