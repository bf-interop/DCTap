    <bf:content>
      <bf:Content rdf:about="http://id.loc.gov/vocabulary/contentTypes/tdi">
	<rdfs:label>two-dimensional moving image</rdfs:label>
	<bf:code>tdi</bf:code>
      </bf:Content>
    </bf:content>
    <bf:capture>
      <bf:Capture>
	<rdfs:label>Filmed on November 21, 1971 at the WTTG-TV studio, 5151 Wisconson Ave. in Tenleytown, Washington, D.C.</rdfs:label>
      </bf:Capture>
    </bf:capture>
    <bf:summary>
      <bf:Summary>
	<rdfs:label>Alice Travis introduces herself, describes the genesis of the Black history game show, Bungo and gives a brief explanation of how it is played, which is similar to Bingo. She indicates that an abbreviated version of the show Bungo was intended to follow the promo, but it is not included in this video.</rdfs:label>
      </bf:Summary>
    </bf:summary>
    <bf:subject>
      <bf:Topic rdf:about="http://id.loc.gov/authorities/subjects/sh2008002467">
	<rdfs:label xml:lang="en">Television quiz shows</rdfs:label>
	<bflc:marcKey>150  $aTelevision quiz shows</bflc:marcKey>
      </bf:Topic>
    </bf:subject>
    <bf:genreForm>
      <bf:GenreForm rdf:about="http://id.loc.gov/authorities/genreForms/gf2011026469">
	<rdfs:label xml:lang="en">Promos (Television commercials)</rdfs:label>
	<bflc:marcKey>155  $aPromos (Television commercials)</bflc:marcKey>
      </bf:GenreForm>
    </bf:genreForm>
