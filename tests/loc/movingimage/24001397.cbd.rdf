    <bf:tableOfContents>
      <bf:TableOfContents>
	<rdfs:label>Bungo title sequence (approximately 40 sec.) -- 1926 film clip of Bill Robinson running backwards (approximately 15 sec.) -- 1926 film clip of Fokker airplane "Josephine Ford" flying over Arctic (approximately 20 sec.).</rdfs:label>
      </bf:TableOfContents>
    </bf:tableOfContents>
    <bf:capture>
      <bf:Capture>
	<rdfs:label>Filmed on February 26, 1972 at the WTTG-TV studio, 5151 Wisconson Ave. in Tenleytown, Washington, D.C.</rdfs:label>
      </bf:Capture>
    </bf:capture>
    <bf:summary>
      <bf:Summary>
	<rdfs:label>Title sequence and clips used to accompany questions in unaired pilot of Black history trivia quiz show, Bungo.</rdfs:label>
      </bf:Summary>
    </bf:summary>
