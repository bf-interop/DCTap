    bf:summary [ a bf:Summary ;
            rdfs:label "Documentary short film featuring one of the earliest gay pride demonstration marches, the first Christopher Street Liberation Day March, held in New York, New York, on June 28, 1970, to commemorate the first anniversary of the Stonewall Riots. Covering about fifty blocks and drawing just a few thousand participants, it and marches like it held the same year in Chicago, San Francisco, and Los Angeles eventually led to hundreds of Pride parades throughout the world in the following decades."@en ] ;
    bf:title [ a bf:Title ;
            rdfs:label "Gay and proud /" ;
            bflc:nonSortNum "0" ;
            bf:mainTitle "Gay and proud /" ] .

