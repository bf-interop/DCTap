    bf:note [ a bf:Note ;
            rdfs:label "\"Alpha Video classics.\"--menu frames."@en ],
        [ a bf:Note,
                oclcbf:SystemDetailsNote ;
            rdfs:label "DVD-R, NTSC; full frame (1.33:1) presentation."@en ],
        [ a bf:Note ;
            rdfs:label "The South Philadelphia Hebrew Association's after-school basketball program in the early 1900's evolved into semi-pro competition under the leadership of one of it's players, Eddie Gottlieb, and grew and became an integral part of today's National Basketball Association..Many players from the long history of Philadelphia teams offer colorful reminiscences in this film."@en ],
        [ a bf:Note,
                <http://id.loc.gov/vocabulary/mnotetype/physical> ;
            rdfs:label "sound, color with black and white sequences ;"@en ] ;
