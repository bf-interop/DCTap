    bf:summary [ a bf:Summary ;
            rdfs:label "(CIT): The Joseph Leiter NLM/MLA Lecture was established in 1983 to stimulate intellectual liaison between the MLA and the NLM. Leiter was a major contributor in cancer research at the National Cancer Institute and a leader at NLM as a champion of medical librarians and an informatics pioneer. He served as NLM Associate Director for Library Operations from 1965 to 1983. Please use this link for the interactive portion of the presentation: https://go.osu.edu/leiter2022."@en ] ;
    bf:title [ a bf:VariantTitle ;
            bflc:marcKey "246 1  $i Title on speaker's PowerPoint: $a Data communities : $b room for everyone, roles for librarians" ;
            bf:mainTitle "Data communities :" ;
            bf:note [ a bf:Note ;
                    rdfs:label "Title on speaker's PowerPoint:"@en ] ;
            bf:subtitle "room for everyone, roles for librarians" ],
        [ a bf:Title ;
            rdfs:label "Data management, sharing and re-use /" ;
            bflc:nonSortNum "0" ;
            bf:mainTitle "Data management, sharing and re-use /" ] .

