    bf:summary [ a bf:Summary ;
            rdfs:label "(CIT): The Demystifying Medicine Series, jointly sponsored by FAES and NIH, includes presentations on pathology, diagnosis, and therapy in the context of major disease problems and current research. Primarily directed toward PhD students, clinicians and program managers, this series is designed to help bridge the gap between advances in biology and their application to major human diseases. Each session includes clinical and basic science components presented by NIH staff and invitees. All students, trainees, fellows, and staff are welcome to participate."@en ] ;
    bf:title [ a bf:VariantTitle ;
            bflc:marcKey "246 1  $a Role of Epstein-Barr virus and molecular mimicry in autoimmune disease" ;
            bf:mainTitle "Role of Epstein-Barr virus and molecular mimicry in autoimmune disease" ],
        [ a bf:Title ;
            rdfs:label "Demystifying medicine. The role of Epstein-Barr virus and molecular mimicry in autoimmune disease /" ;
            bflc:nonSortNum "0" ;
            bf:mainTitle "Demystifying medicine." ;
            bf:partName "The role of Epstein-Barr virus and molecular mimicry in autoimmune disease /" ] .

