    bf:summary [ a bf:Summary ;
            rdfs:label "The internet is now everywhere. It's a part of how we drive our cars, flush our toilets and even keep an eye on our sleeping babies. We have wholeheartedly embraced the convenience of connected \"smart\" objects without fully understanding the potential consequences to our health, our communities and the planet."@en ] ;
    bf:title [ a bf:Title ;
            rdfs:label "The internet of everything /" ;
            bflc:nonSortNum "4" ;
            bf:mainTitle "The internet of everything /" ] .

