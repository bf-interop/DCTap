        <https://id.oclc.org/worldcat/entity/E39PBJgt3k8FThFDJMfjp8rpfq>,
        <https://id.oclc.org/worldcat/entity/E39PBJjCKvFkHQ3F9QhY6vw3cP>,
        <https://id.oclc.org/worldcat/entity/E39PBJtxgQXMWqmjMjjwXRHgrq> ;
    bf:summary [ a bf:Summary ;
            rdfs:label "\"Through a combination of first-person interviews and those with friends, family, and colleagues, Biography® explores the life of the President from his childhood in Honolulu to his successful bid to become America's 44th Chief Executive. Learn about his struggles to find an identity as a teenager and how his dedication to learning and compassion for his peers propelled him through two of the top universities in the U.S. Follow him through his days as a community organizer in Chicago, as a state senator in Illinois, as a member of the U.S. Senate, and as his party's nominee for President of the United States. Finally, take a look at how he harnessed the power of change to connect with millions of Americans on his way to winning the White House in November 2008.\"--Described and Captioned Media Program website."@en ] ;
    bf:tableOfContents [ a bf:TableOfContents ;
            rdfs:label "Introduction -- Early life -- Youth in Hawaii -- Harvard law -- Public life -- 2004 Convention -- Primaries -- Presidential win." ] ;
    bf:title [ a bf:Title ;
            rdfs:label "Barack Obama inaugural edition /" ;
            bflc:nonSortNum "0" ;
            bf:mainTitle "Barack Obama inaugural edition /" ],
        [ a bf:VariantTitle ;
            bflc:marcKey "246 1  $i At head of title on disc surface and container: $a Black enterprise, in our footsteps video collection" ;
            bf:mainTitle "Black enterprise, in our footsteps video collection" ;
            bf:note [ a bf:Note ;
                    rdfs:label "At head of title on disc surface and container:"@en ] ],
        [ a bf:VariantTitle ;
            bflc:marcKey "246 1  $i Title on container spine: $a Black enterprise : $b Barack Obama inaugural edition" ;
            bf:mainTitle "Black enterprise :" ;
            bf:note [ a bf:Note ;
                    rdfs:label "Title on container spine:"@en ] ;
            bf:subtitle "Barack Obama inaugural edition" ] .

