        <https://id.oclc.org/worldcat/entity/E39PBJtxgQXMWqmjMjjwXRHgrq> ;
    bf:summary [ a bf:Summary ;
            rdfs:label "In 2015, Niya Kenny, an African American female student at Spring Valley High School in Columbia South Carolina was violently removed from the classroom by school police. The incident was caught on video, spurring national discussion on the racial power structure and the routine mistreatment of African Americans by authorities."@en ] ;
    bf:title [ a bf:Title ;
            rdfs:label "On these grounds /" ;
            bflc:nonSortNum "0" ;
            bf:mainTitle "On these grounds /" ] .

