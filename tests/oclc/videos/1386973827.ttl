    bf:summary [ a bf:Summary ;
            rdfs:label "Those little shacks out along the road to the city dump are homes, homes in which you will find mothers, wives, daughters, sweethearts, and all those other things which go to make up life's comedies and tragedies. One such of these places was the home of the widow Malone who had a son how worked as a Western Union messenger who interrupts a burglary and follows the thieves until they are caught."@en ] ;
    bf:title [ a bf:Title ;
            rdfs:label "The midnight message /" ;
            bflc:nonSortNum "4" ;
            bf:mainTitle "The midnight message /" ] .

