    bf:summary [ a bf:Summary ;
            rdfs:label "\"More fun and comedy await you as we explore more great cartoons from animation's Golden Era!  Whether it's experimenting with different visual styles in The Dover Boys, parodying Disney's Fantasia in Pigs in a Polka, or making a deep socio political commentary in The Fifth-Column Mouse, these great historical cartoon treasures are a sure delight for animation fans and collectors alike!\"--Container."@en ] ;
    bf:tableOfContents [ a bf:TableOfContents ;
            rdfs:label "Fresh hare (director, Friz Freleng, Aug. 1942) -- Eatin' on the cuff, or, The moth who came to dinner (director, Robert Clampett, Aug. 1942) -- Fox pop (director, Chuck Jones, Sept. 1942) -- The Dover Boys at Pimento University (director Chuck Jones, Sept. 1942) -- The sheepish wolf (director, Friz Freleng, Oct. 1942) -- A tale of two kitties (director, Robert Clampett, Nov. 1942) -- Ding dog daddy (director, Friz Freleng, Dec. 1942) -- The case of the missing hare (director, Chuck Jones, Dec. 1942) -- Confusions of a nutzy spy (director, Norm McCabe, Jan. 1943) -- Pigs in a polka (director, Friz Freleng, Feb. 1943) -- To duck or not to duck (director, Chuck Jones, Mar. 1943) -- The fifth-column mouse (director, Friz Freleng, March 1943) -- Flop goes the weasel (direcor, Chuck Jones, March 1943)" ] ;
    bf:title [ a bf:Title ;
            rdfs:label "The wackiest cartoons of all time! Volume 4 :" ;
            bflc:nonSortNum "4" ;
            bf:mainTitle "The wackiest cartoons of all time!" ;
