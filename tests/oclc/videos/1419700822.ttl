    bf:summary [ a bf:Summary ;
            rdfs:label "\"Iom Romì\" chronicles a day in the life of the contemporary Jewish community of Rome, which traces its origins to the times of the Empire - a microcosm with unique rituals and traditions, both fiercely independent and distinctly Roman."@en ] ;
