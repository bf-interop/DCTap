        <https://id.oclc.org/worldcat/entity/E39PBJrCc3y6qrrFCvQ6tMh4MP> ;
    bf:summary [ a bf:Summary ;
            rdfs:label "\"Diaspora” is a documentary about the formation of Caribbean identity through culture, ideas, and art as it traveled, mixed, and communicated within the migration to and from the region. It features interviews from the likes of Julia Alvarez (In the Time of the Butterflies), as well as a visual journey across the Atlantic: from the Dominican Republic, Cuba, and Puerto Rico all the way to the isle of Goree in Dakar, Senegal."@en ] ;
    bf:title [ a bf:Title ;
            rdfs:label "Diáspora /" ;
            bflc:nonSortNum "0" ;
            bf:mainTitle "Diáspora /" ] .

