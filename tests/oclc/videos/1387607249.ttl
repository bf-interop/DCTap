    bf:summary [ a bf:Summary ;
            rdfs:label "This Excel workbook determines tsunami loads in both Imperial and metric units in accordance with the 2024 IBC and ASCE/SEI 7-22. Both an RHT Analysis and an Energy Grade Line Analysis can be performed to determine inundation depths and flow velocities based on user input. Hydrodynamic lateral forces are calculated for application on the overall building or structure and on structural components. Debris impact forces are also determined due to wood logs and poles, vehicles, tumbling boulders and concrete debris, and shipping containers."@en ] ;
    bf:title [ a bf:Title ;
            rdfs:label "Tsunami Loads :" ;
            bflc:nonSortNum "0" ;
            bf:mainTitle "Tsunami Loads :" ] .

