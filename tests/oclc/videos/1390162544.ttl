    bf:summary [ a bf:Summary ;
            rdfs:label "\"Renowned Hopi filmmaker Victor Masayesva, Jr. explores the centrality of corn for the Hopi, Nahua, and Maya, tracing the role of corn from creation stories to today's struggles against climate change. The film presents complex interrelationships between humans, plants, food systems, animals, birds, ceremonies and the cycles of the earth, sun and moon within the universe from a Hopi, Maya, and Nahua perspective. By tracing the lineage and mysterious origins of corn, we gain a deeper understanding of the ancestry of communities that transcend borders.\"-- taken from distributor web site."@en ],
        [ a bf:Summary ;
            rdfs:label "\"'Waaki' honors the world community connected by corn. Many indigenous people, including the Hopi, Nahua and Maya, have a special connection to maize / corn, synthesized in the statement : \"We are corn.\" There are many songs, ceremonies, and ritual practices affirming this connection. In between the portals of birth and death, the people sing, dance, and celebrate their corn origins and identity. 'Waaki' is about the dialogue possible from this experience : How did maize / corn domesticate us? How did we become inter-dependent with other species? How has this relationship improved our lives? The human capacity for tolerance and compassion is celebrated in 'Waaki' - a self-awareness needed in these days when people are becoming more intolerant of difference. Our gratitude to Hopi, Maya, Nahua, and Otomi communities for sharing their knowledge.\"-- taken from back cover of container label."@en ] ;
    bf:tableOfContents [ a bf:TableOfContents ;
            rdfs:label "1. Creation stories (Historias de Creación) -- 2. Nahua Creation (Creación Nahua) -- 3. Migrations (Migraciones) -- 4. Teocintle - Mother Corn (Madre de Maíz) -- 5. Prayers (Oraciones) -- 6. Corn ancestors (Antepasados del maíz) -- 7. Relations (Relaciones) -- 8. Spirit (Espíritu) -- 9. Future migrations (Futuras migraciones) -- 10. Survival (Supervivencia) -- 11. Compassion (Compasión)." ] ;
    bf:title [ a bf:VariantTitle,
                <http://id.loc.gov/vocabulary/vartitletype/por> ;
            bflc:marcKey "246 30 $a Sanctuary" ;
            bf:mainTitle "Sanctuary" ],
        [ a bf:Title ;
            rdfs:label "Waaki (Sanctuary) /" ;
            bflc:nonSortNum "0" ;
            bf:mainTitle "Waaki (Sanctuary) /" ] .

