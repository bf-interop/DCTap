    bf:hasInstance <https://id.oclc.org/worldcat/entity/1433664840> ;
    bf:language <http://id.loc.gov/vocabulary/languages/eng> ;
    bf:note [ a bf:Note,
                <http://id.loc.gov/vocabulary/mnotetype/participants> ;
            rdfs:label "Performers: Eric Clapton, B.B. King, Buddy Guy, David Hidalgo, ZZ Top, Sheryl Crow, Steve Winwood, Jeff Beck, and others."@en ;
            bflc:marcKey "511 0  $a Performers: Eric Clapton, B.B. King, Buddy Guy, David Hidalgo, ZZ Top, Sheryl Crow, Steve Winwood, Jeff Beck, and others." ] ;
    bf:originDate "2010"^^<http://id.loc.gov/datatypes/edtf> ;
    bf:tableOfContents [ a bf:TableOfContents ;
            rdfs:label "Disc 1. Promise land (Sonny Landreth with Eric Clapton) -- Z. Rider (Sonny Landreth) -- Traveling shoes (Robert Randolph & The Family Band) -- Going down (Pino Daniele, Joe Bonamassa, Robert Randolph & The Family Band) -- Killing floor (Robert Cray with Jimmie Vaughan & Hubert Sumlin) -- Six strings down (Jimmie Vaughan with Robert Cray & Hubert Sumlin) -- Waiting for the bus ; Jesus just left Chicago (ZZ Top) -- Gypsy blood (Doyle Bramhall II) -- In my time of dying (Jesus make up my dying bed) (Doyle Bramhall II) -- Bright lights (Gary Clark Jr.) -- Long road home (Sheryl Crow with Derek Trucks, Susan Tedeschi, Doyle Bramhall II & Gary Clark Jr.) -- Our love is fading (Sheryl Crow with Eric Clapton, Doyle Bramhall II & Gary Clark Jr.) -- Blackwaterside (Bert Jansch) -- Mississippi blues (Stefan Grossman & Keb' Mo') -- Roll and tumble blues (Stefan Grossman & Keb' Mo') -- One more last chance (Vince Gill with Keb' Mo', James Burton, Earl Klugh & Albert Lee) -- Mystery train (Vince Gill with James Burton, Albert Lee, James Burton & Earl Klugh) -- Lay down Sally ( Vince Gill with Sheryl Crow, Keb' Mo', Albert Lee, James Burton & Earl Klugh) -- Angelina (Earl Klugh) -- Vonetta (Earl Klugh) -- Who did you think I was ; Ain't no sunshine (John Mayer Trio)." ],
        [ a bf:TableOfContents ;
            rdfs:label "Disc 2. Midnight in Harlem (Derek Trucks & Susan Tedeschi Band) -- Coming home (Derek Trucks & Susan Tedeschi Band with Warren Haynes) -- Soulshine (Warren Haynes) -- Don't keep me wondering (David Hidalgo & Cesar Rosas with Derek Trucks) -- Space captain (Derek Trucks & Susan Tedeschi Band with Warren Haynes, David Hidalgo, Cesar Rosas & Chris Stainton) -- Five long years ; Miss you (Buddy Guy with Jonny Lang & Ronnie Wood) -- Hammerhead ; Nessun dorma (Jeff Beck) -- Crossroads (Eric Clapton) -- Hands of the saints (Citizen Cope & Eric Clapton) -- I shot the sheriff (Eric Clapton) -- Shake your money maker (Eric Clapton & Jeff Beck) -- Had to cry today (Steve Winwood & Eric Clapton) -- Voodoo Chile (Eric Clapton & Steve Winwood) -- Dear Mr. Fantasy (Steve Winwood & Eric Clapton) -- The thrill is gone (B.B. King & ensemble)." ] ;
    bf:title [ a bf:Title ;
            rdfs:label "Crossroads: Eric Clapton Guitar Festival 2010 /" ;
            bflc:nonSortNum "0" ;
            bf:mainTitle "Crossroads: Eric Clapton Guitar Festival 2010 /" ],
        [ a bf:VariantTitle,
                <http://id.loc.gov/vocabulary/vartitletype/por> ;
            bflc:marcKey "246 30 $a Eric Clapton Guitar Festival 2010" ;
            bf:mainTitle "Eric Clapton Guitar Festival 2010" ] .

