    bf:summary [ a bf:Summary ;
            rdfs:label "(The big game) A scientist has invented a method of mind control, and many are interested in him and his research."@en ],
        [ a bf:Summary ;
            rdfs:label "(Day of the wolves) A gang takes over an entire town, in order to rob the town bank."@en ],
        [ a bf:Summary ;
            rdfs:label "(The Peking blonde) Female operatives are set against Cold War villains."@en ],
        [ a bf:Summary ;
            rdfs:label "(Action man)  Ex-crook and now propietor of a tabac in Paris, is convinced to commit one last grand crime."@en ] ;
    bf:tableOfContents [ a bf:TableOfContents ;
            rdfs:label "Action man / directed by Kean Delannoy (1967 ; 97 min.) -- Day of the wolves / directed by Ferde Grofe, Jr. (1973 ; 92 min.) -- Big game, aka Control factor / directed by Robert Day (1972 ; 94 min.) -- Peking blonde / directed by Nicolas Gessner (1967 ; 82 min.)." ] ;
