    bf:summary [ a bf:Summary ;
            rdfs:label "Specially Processed American Me by Jaime Sunwoo is a surreal autobiographical performance using SPAM, the canned meat, as a portal into her Asian American upbringing and her family's experiences of the Korean War. It investigates SPAM's legacy in the military, its significance in the Asia-Pacific, and its influence on Asian cuisine through music, shadowplay, and cooking. Oscillating wildly between absurd humor and sober tragedy, Specially Processed American Me is a thought-provoking exploration of one of America's most misunderstood foods."@en ] ;
    bf:title [ a bf:Title ;
            rdfs:label "Specially processed American me /" ;
            bflc:nonSortNum "0" ;
            bf:mainTitle "Specially processed American me /" ] .

