    bf:summary [ a bf:Summary ;
            rdfs:label "Uncertain of what he wants to do with his life, college graduate Benjamin Braddock returns home. And when the wife of his father's business partner, the sexy Mrs. Robinson, seduces him, the affair only deepens his confusion. That is, until he meets the girl of his dreams. But there's one problem-- she's Mrs. Robinson's daughter."@en ] ;
    bf:title [ a bf:Title ;
            rdfs:label "The graduate /" ;
            bflc:nonSortNum "4" ;
            bf:mainTitle "The graduate /" ] .

