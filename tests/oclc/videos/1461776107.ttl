    bf:subject [ a bf:Person ;
            rdfs:label "Nash, John F., 1928-2015." ;
            bflc:marcKey "600 14 $a Nash, John F., $d 1928-2015. $0 https://libris.kb.se/khw07c033l9vczw#it" ;
            skos:relatedMatch <https://libris.kb.se/khw07c033l9vczw#it> ] ;
    bf:summary [ a bf:Summary ;
            rdfs:label "Vinnare av 4 Oscar®, bland annat för bästa film. A Beautiful Mind är regisserad av Oscar®-vinnaren Ron Howard ochproducerad av Oscar®-vinnaren Brian Grazer. I A Beautiful Mind ser vi Russel Crowe i ett otroligt porträtt av den genialiske matematikern John Nash, på väg att bli internationellt erkänd när han dras in i en mystisk konspiration. Det är bara hans hängivna fru (Oscar-vinnaren Jennifer Connelly) som kan hjälpa honom i denna starka berättelse om mod, passion och triumf."@sv ] ;
    bf:title [ a bf:Title ;
            rdfs:label "A Beautiful Mind /" ;
            bflc:nonSortNum "2" ;
            bf:mainTitle "A Beautiful Mind /" ] .

