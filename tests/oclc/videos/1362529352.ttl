    bf:summary [ a bf:Summary ;
            rdfs:label "\"Gold of the Himalayas : The Changpa people live cut off from the rest of the world on a barren, 4,000-meter-high plateau in the southeast of Ladakh, in the Kashmir Himalayas. Here, livestock must search far and wide to pry something edible from the earth. Inhospitable as it is, the region is also home to a living treasure : Changpa goats, which grow a fine wool -- but only at extremely high altitudes and in bitterly cold winters. The wool is then brushed out in the early summer and sold in the capital city as the precious Pashmina, the \"Gold of the Changthang.\" This program follows a group of Changpa nomads as they undertake another arduous trading journey -- one that will make possible more beautiful cashmere textiles valued by garment manufacturers and consumers around the world.\"--taken from container label."@en ] ;
    bf:tableOfContents [ a bf:TableOfContents ;
            rdfs:label "Gold of the Himalayas : Pashmina wool -- Generational tradition -- Marriage : Polyandry -- Nightfall in the Changthang -- Daytime activities -- Changpa : Decisions and dice -- Changpa : Women's activities -- Horse round-up & breaking up camp -- Nomads on the move -- New camp for the Changpa -- Buddhist rituals for wellness -- Changpa : Men's work -- Threat to traditions -- In honor of the spirits -- In honor of the Buddha -- New leader -- Traditional horse race -- Winter in the Changthang -- Winter cold and Pashmina -- Pashmina goes to market -- Market in Leh, capital of Ladakh -- Religious devotion -- Marriage made official -- Changpa : Uncertain future -- Credits." ] ;
    bf:title [ a bf:VariantTitle,
                <http://id.loc.gov/vocabulary/vartitletype/por> ;
            bflc:marcKey "246 30 $a Nomads in Ladakh" ;
            bf:mainTitle "Nomads in Ladakh" ],
        [ a bf:VariantTitle ;
            bflc:marcKey "246 1  $i Title on disc label: $a Nomads : $b Gold of the Himalayas" ;
            bf:mainTitle "Nomads :" ;
            bf:note [ a bf:Note ;
                    rdfs:label "Title on disc label:"@en ] ;
            bf:subtitle "Gold of the Himalayas" ],
        [ a bf:Title ;
            rdfs:label "Gold of the Himalaya :" ;
            bflc:nonSortNum "0" ;
            bf:mainTitle "Gold of the Himalaya :" ],
        [ a bf:VariantTitle ;
            bflc:marcKey "246 1  $i Title on container label: $a Gold of the Himalayas" ;
            bf:mainTitle "Gold of the Himalayas" ;
            bf:note [ a bf:Note ;
                    rdfs:label "Title on container label:"@en ] ] .

