    bf:summary [ a bf:Summary ;
            rdfs:label "Portrays the artistic endeavors and the personal journeys of two artists, Zhang Hongtu (b. 1943) and Zhang Jian-Jun (b. 1955.) Determined to escape the artistic leash imposed by Chinese cultural control, they emigated to the U.S. and became part of the Chinese contemporary art community of New York."@en ] ;
    bf:title [ a bf:Title ;
            rdfs:label "Yellow Ox Mountain /" ;
            bflc:nonSortNum "0" ;
            bf:mainTitle "Yellow Ox Mountain /" ] .

