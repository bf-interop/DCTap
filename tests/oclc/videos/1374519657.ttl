    bf:summary [ a bf:Summary ;
            rdfs:label "\"Terry wants to ask Allison to marry her, but can't afford a ring. She enlists Ben, her guitar-crooning friend, to help her carry out a ring-less proposal, but when Ben is distracted by a handsome passer-by, Terry has to wing it on her own.\"--Container."@en ] ;
