            rdfs:label "Vuxövergripande."@sv ] ;
    bf:subject [ a bf:Place,
                madsrdf:Geographic ;
            rdfs:label "Förenta staterna." ;
            bflc:marcKey "651  7 $a Förenta staterna. $0 https://id.kb.se/term/sao/F%C3%B6renta%20staterna $2 sao" ;
            bf:source <http://id.loc.gov/vocabulary/subjectSchemes/sao> ;
            skos:relatedMatch <https://id.kb.se/term/sao/F%C3%B6renta%20staterna> ],
        <https://id.kb.se/term/sao/1960-talet>,
        <https://id.kb.se/term/sao/Beat%20generation>,
        <https://id.kb.se/term/sao/Reseskildringar> ;
    bf:summary [ a bf:Summary ;
            rdfs:label "Författaren Ken Kesey bestämde sig sommaren 1964 för att tillsammans med vänner köra tvärs över USA till världsutställningen i New York. För att transportera sig köpte man en gammal skolbuss från 30-talet som byggdes om och målades psykedeliskt av kultfiguren Neal Cassady, som även blev resans chaufför. Neal ingick i en löst sammanhängande grupp av medresenärer som kallade sig \"The Merry Pranksters\". På resan från Kalifornien till New York skulle man propagera för användandet av droger typ marijuana och LSD. Allt filmades på 16 mm färgfilm. Det blev en äventyrlig tripp med många möten längs resan - bland annat med beatnikförfattarna Jack Kerouac och Allen Ginsberg samt psykologen och drog- entusiasten Timothy Leary."@sv ] ;
    bf:title [ a bf:Title ;
            rdfs:label "Magic Trip." ;
            bflc:nonSortNum "0" ;
            bf:mainTitle "Magic Trip." ] ;
    bf:validDate "20120525/20150414" .

