    bf:genreForm <http://id.loc.gov/authorities/genreForms/gf2011026723>,
        <https://id.kb.se/term/saogf/Tv-program> ;
    bf:hasInstance <https://id.oclc.org/worldcat/entity/1410015356> ;
    bf:intendedAudience <http://id.loc.gov/vocabulary/maudience/pad> ;
