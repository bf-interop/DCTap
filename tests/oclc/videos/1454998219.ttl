    bf:subject [ a bf:Person ;
            rdfs:label "Clarke, Alan, 1935-1990." ;
            bflc:marcKey "600 10 $a Clarke, Alan, $d 1935-1990." ;
            bf:identifiedBy [ a bf:Local ;
                    bf:assigner [ a bf:Organization ;
                            bf:code "OCoLC" ] ;
                    rdf:value "oca4799653" ] ;
            bf:source <http://id.loc.gov/authorities/subjects> ],
        <https://id.oclc.org/worldcat/entity/E39PBJw8RMBG4dHxQ86mCDbjmd> ;
    bf:summary [ a bf:Summary ;
            rdfs:label "This re-packaged collection brings together twenty-two stand-alone BBC TV dramas that Alan Clarke directed between 1969 and 1989, including such neglected classics as To encourage the others, Horace, Penda's Fen, Diane, Contact, Christine and Elephant, and includes Scum plus Clarke's director's  cCut of The firm, assembled from his personal answer print, discovered in 2015. This 12-disc box set (11 Blu-rays / 1 DVD) also includes a raft of additional materials, including an introduction to The firm by David Leland, extracts from BBC discussion shows Open Air and Tonight, plus documentaries and eight audio commentaries. -- British Film Institute."@en ] ;
    bf:tableOfContents [ a bf:TableOfContents ;
            rdfs:label "Disc 1. The last train through Harecastle Tunnel (1969) (76 mins) ; Sovereign's Company (1970) (77 mins) -- Disc 2. The hallelujah handshake (1970) (75 mins) ; To encourage the others (1972) (104 mins) -- Disc 3. Under the age (1972) (31 mins) ; Horace (1972) (90 mins) -- Disc 4. The love-girl and the innocent (1973) (127 mins) ; Penda's Fen (1974) (89 mins) -- Disc 5. A follower for Emily (1974) (64 mins) ; Diane (1975) (97 mins) -- Disc 6. Funny Farm (1975) (93 mins) ; Scum (1977) (75 mins) -- Disc 7. Bukovsky (documentary) (1977) (50 mins) ; Nina (1978) (76 mins) -- Disc 8. Danton's death (1978) (95 mins) ; Beloved enemy (1981) (69 mins) -- Disc 9. Psy-warriors (1981) (73 mins) ; Baal (1982) (64 mins) -- Disc 10. Stars of the Roller State Disco (1984) (72 mins) ; Contact (1985) (67 mins) -- Disc 11. Christine (1987) (51 mins) -- Disc 12. Elephant (1989) (38 mins) ; The firm (1989) (67 mins/68 mins) (director's cut)." ] ;
    bf:title [ a bf:Title ;
            rdfs:label "Dissent & disruption :" ;
            bflc:nonSortNum "0" ;
            bf:mainTitle "Dissent & disruption :" ],
        [ a bf:VariantTitle,
                <http://id.loc.gov/vocabulary/vartitletype/por> ;
            bflc:marcKey "246 30 $a Alan Clarke at the BBC (1969-1989)" ;
            bf:mainTitle "Alan Clarke at the BBC (1969-1989)" ],
        [ a bf:VariantTitle ;
            bflc:marcKey "246 3  $a Dissent and disruption" ;
            bf:mainTitle "Dissent and disruption" ] .

