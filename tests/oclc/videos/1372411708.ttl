        <https://id.oclc.org/worldcat/entity/E39Qhp4vBb9Md7HwVyg64R3RHK>,
        <https://id.oclc.org/worldcat/entity/E39Qhp4vBbvj6mkBxBtKVVV6HK> ;
    bf:summary [ a bf:Summary ;
            rdfs:label "An exploration of the 1945 bombings of Hiroshima and Nagasaki that reveals the suppressed footage of human suffering caused by the US nuclear bombings. It focuses on the brave camera crews who risked their lives capturing the aftermath, starting with a Japanese newsreel crew and later continuing under the supervision of the US Army. This vital footage was classified top secret and buried by American officials for decades to conceal the true human cost as the nuclear arms race escalated."@en ] ;
    bf:tableOfContents [ a bf:TableOfContents ;
            rdfs:label "52 minute version -- 29 minute version." ] ;
    bf:title [ a bf:Title ;
            rdfs:label "Atomic cover-up /" ;
            bflc:nonSortNum "0" ;
            bf:mainTitle "Atomic cover-up /" ] .

