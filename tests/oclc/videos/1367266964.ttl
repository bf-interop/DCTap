    bf:summary [ a bf:Summary ;
            rdfs:label "In 2035, smoking is illegal except in the dystopian, nicotine-stained \"Smoking Section\" controlled by the Vice Lord. Cigarette Girl, all underwear, curves and va-va-voom, sells cigarettes on the black market, while struggling to kick her own habit. Hunted by ghosts of her addictions, Cigarette Girl discovers she'd kill for a smoke."@en ] ;
    bf:title [ a bf:Title ;
            rdfs:label "Cigarette Girl /" ;
            bflc:nonSortNum "0" ;
            bf:mainTitle "Cigarette Girl /" ] .

