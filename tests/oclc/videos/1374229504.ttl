    bf:summary [ a bf:Summary ;
            rdfs:label "Organ Cinema is an ever-expanding filmed encyclopedia of the organ and its history and repertoire. All the films made by Fugue State Films over the last fifteen years can be watched here. Many more films will be made and added. Ultimately there will be a set of films about each important historical or geographical school of organ music."@en ] ;
    bf:title [ a bf:VariantTitle,
                <http://id.loc.gov/vocabulary/vartitletype/por> ;
            bflc:marcKey "246 30 $a Filmed encyclopedia of the pipe organ and its music" ;
            bf:mainTitle "Filmed encyclopedia of the pipe organ and its music" ],
        [ a bf:Title ;
            rdfs:label "Organ cinema :" ;
            bflc:nonSortNum "0" ;
            bf:mainTitle "Organ cinema :" ],
        [ a bf:VariantTitle ;
            bflc:marcKey "246 1  $i Also known as: $a Filmed encyclopedia of the organ and its music" ;
            bf:mainTitle "Filmed encyclopedia of the organ and its music" ;
            bf:note [ a bf:Note ;
