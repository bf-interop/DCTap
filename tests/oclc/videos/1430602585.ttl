        [ a bf:Note,
                <http://id.loc.gov/vocabulary/mnotetype/participants> ;
            rdfs:label "Featuring Patricia Rodney, Angela Davis, and Gina Miller. Composer: Michael L. Worrall; drone: Ackeem Thomas, Jonathan Robertson. Camera: Daniel Schwartz (Atlanta), Lawrence Rickford (Oakland), Khaleed Aboubakar (Tanzania), Jahsen Levy (Jamaica), Ackeem Thomas (Guyana), Ajao Adewunmi (London). Director of photography: Daniyal Harris-Vajda. Set and costume designer: Irene Rado-Vajda; history consultant: Ade Browne; assistant cameraman (US): Francis Bautista; additional camera: Leon 'Ice' Gonsalves, Owen Rhys Davies; additional music: Rakesh S. Bishunlall, Amar Ramessar."@en ;
            bflc:marcKey "511 0  $a Featuring Patricia Rodney, Angela Davis, and Gina Miller. Composer: Michael L. Worrall; drone: Ackeem Thomas, Jonathan Robertson. Camera: Daniel Schwartz (Atlanta), Lawrence Rickford (Oakland), Khaleed Aboubakar (Tanzania), Jahsen Levy (Jamaica), Ackeem Thomas (Guyana), Ajao Adewunmi (London). Director of photography: Daniyal Harris-Vajda. Set and costume designer: Irene Rado-Vajda; history consultant: Ade Browne; assistant cameraman (US): Francis Bautista; additional camera: Leon 'Ice' Gonsalves, Owen Rhys Davies; additional music: Rakesh S. Bishunlall, Amar Ramessar." ] ;
