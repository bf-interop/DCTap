            bf:note [ a bf:Note ;
                    rdfs:label "At head of title on container:"@en ] ],
        [ a bf:VariantTitle ;
            bflc:marcKey "246 3  $a What they don't want you to know" ;
            bf:mainTitle "What they don't want you to know" ],
