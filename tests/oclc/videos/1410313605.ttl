    bf:summary [ a bf:Summary ;
            rdfs:label "\"The award-winning documentary An Undeniable Voice is a 16-minute film that tells the story of longtime family friend Sam Harris, who is believed to have been one of the youngest survivors of Nazi concentration camps. The documentary, Arana's directorial debut, is another collaboration with Stone.\"--From Cornell AAP alumni archives."@en ] ;
    bf:title [ a bf:Title ;
            rdfs:label "An undeniable voice /" ;
            bflc:nonSortNum "3" ;
            bf:mainTitle "An undeniable voice /" ],
