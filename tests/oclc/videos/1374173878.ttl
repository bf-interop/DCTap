    bf:summary [ a bf:Summary ;
            rdfs:label "Den Oscar®-belönade regissören Steven Spielberg är tillbaka tillsammans med den tvåfaldigt Oscar®-belönade Tom Hanks och Oscar®-vinnaren Catherine Zeta-Jones i denna kritikerrosade komedi. Viktor Navorski (Hanks) kommer till flygplatsen JFK och blir ett oskyldigt offer för byråkratiska problem som gör att han varken kan återvända till sitt hemland eller komma in i USA. Väl inne i den nöjesfyllda flygplatsen skaffar Viktor vänner, jobb, en romans och uppfyller till slut Amerikas sanna hjärta. [Förlagett]."@sv ] ;
    bf:tableOfContents [ a bf:TableOfContents ;
            rdfs:label "Bonus disc: Bokning av resan: manus & story, Boarding: människorna i terminalen -- Catherine Zeta-Jones som \"Amelia\", Inflight service: the music of The Terminal, I väntan på resan: terminalen byggs upp, Boarding: människorna i terminalen -- Viktor's värld, Landning: flygplatshistorier, Boarding: människorna i terminalen -- Tom Hanks som \"Viktor\", Take-off: så gjordes The Terminal och Fotogalleri." ] ;
    bf:title [ a bf:Title ;
            rdfs:label "The Terminal /" ;
            bflc:nonSortNum "4" ;
            bf:mainTitle "The Terminal /" ] .

