    bf:summary [ a bf:Summary ;
            rdfs:label "\"Hoodz DVD takes you on a live journey from Hoodz to Hoodz around the world. You get to see life in different Hoodz everywhere, the good, the bad & the ugly from the meanest streets to hip hops biggest beefs. Young Jeezy breaks down the street code from the rap game to the raw streetz of ATL [Atlanta]. Witness life from ATL's YG's & Trap Starz + live & uncut from Brooklyn to Memphis!! Hood to hood at its best!!!!\"--Container."@en ] ;
    bf:title [ a bf:VariantTitle,
                <http://id.loc.gov/vocabulary/vartitletype/por> ;
            bflc:marcKey "246 30 $a Street code" ;
            bf:mainTitle "Street code" ],
