            rdfs:label "Hoodz. Street code /" ;
            bflc:nonSortNum "0" ;
            bf:mainTitle "Hoodz." ;
            bf:partName "Street code /" ],
        [ a bf:VariantTitle ;
            bflc:marcKey "246 1  $i Copyright application title: $a Hoodz DVD Magazine: street code" ;
            bf:mainTitle "Hoodz DVD Magazine: street code" ;
            bf:note [ a bf:Note ;
                    rdfs:label "Copyright application title:"@en ] ] .

