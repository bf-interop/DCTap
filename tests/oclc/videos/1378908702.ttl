    bf:summary [ a bf:Summary ;
            rdfs:label "Från baksidestext: I början av 1800-talet skickas den unga föräldralösa Mary till sin moster och morbror för att bo med dem på deras värdshus Jamaica inn. Det dröjer inte länge förrän Mary förstår att värdshuset fungerar som ett tillhåll för ett gäng pirater och hon börjar frukta för sitt liv."@sv ] ;
    bf:title [ a bf:Title ;
            rdfs:label "Jamaica inn /" ;
