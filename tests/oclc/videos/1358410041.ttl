    bf:summary [ a bf:Summary ;
            rdfs:label "A collection of early examples of stop-motion animation, featuring rare Kinex films, originally made in Hollywood for distribution to the new \"home movie\" market of the 1920's. Also includes early silent examples by the medium's pioneers including J. Stuart Blackton and Willis O'Brien."@en ] ;
    bf:tableOfContents [ a bf:TableOfContents ;
            rdfs:label "Early experiments. Princess Nicotine -- The Automatic Moving Company -- Prehistoric poultry -- George Washington in clay -- Miracles in mud -- Swat the fly. The Kinex Studios collection. Red Riding Hood -- Snap the Gingerbread Man -- Chip the Wooden Man -- Daffy doings in Doodlebugville -- Pepper the Pup in Toodle-oo-o -- Hector the Pup -- Horse laffs. All sorts of shorts. Ferda the Ant -- Dolly Daisy in hearts and flowers -- Toyland ice capades -- The peanut vendor -- Mecki introduces himself -- Rock a bye baby -- The peanut vendor -- The Ice Princess. Theatrical & Television Commercials. Lucky Strike commercials (1948) -- Butter commercial (early 50's) -- 'Camel' commercial workprint (late 40's) -- 'King Kong' Volkswagen (1971) -- Glo Coat (mid 60's) -- Chocks (early 60's) -- Brylcreem (early 50's)." ] ;
    bf:title [ a bf:VariantTitle ;
            bflc:marcKey "246 1  $i At head of title: $a Thunderbean presents" ;
            bf:mainTitle "Thunderbean presents" ;
            bf:note [ a bf:Note ;
                    rdfs:label "At head of title:"@en ] ],
        [ a bf:Title ;
            rdfs:label "Stop-motion marvels! :" ;
            bflc:nonSortNum "0" ;
            bf:mainTitle "Stop-motion marvels! :" ] .

