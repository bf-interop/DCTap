        <https://id.oclc.org/worldcat/entity/E39PBJtCD3rcKcPDx6FHmjvrbd> ;
    bf:summary [ a bf:Summary ;
            rdfs:label "Europa: \"An idealistic American (Jean-Marc Barr) travels to postwar Germany to take a job as a sleeping-car conductor for the Zentropa railways- and finds himself plunged into a murky, Kafkaesque world of intrigue and betrayal where the shadow of Nazism hovers menacingly over everything.\"--Publish' website."@en ],
        [ a bf:Summary ;
            rdfs:label "The element of crime: \"From his exile in Cairo, a former police investigator (Michael Elphick) undergoes hypnosis in order to relive his memories of Europe and his last case, for which he went to dangerous lengths to enter into the mind of and catch a serial killer targeting children.\"--Publisher's website."@en ],
        [ a bf:Summary ;
            rdfs:label "Epidemic: \"The filmmaker himself stars as a harried screenwriter whose efforts to complete a script about the outbreak of a deadly disease coincide with a grisly real-life plague.\"--Publisher's website."@en ] ;
    bf:tableOfContents [ a bf:TableOfContents ;
            rdfs:label "The element of crime (AKA : Forbrydelsens element, 1984, 103 min., color, 1.89:1, mono) / Per Holist Filmproduction presents ; directed by Lars von Trier ; screenplay by Lars von Terier & Niels Vørsel -- Epidemic (1987, 106 min., black and white/color, 1.66:1, mono) / Lars von Trier, Elementfilm ; manuskript Lars von Trier & Niels Vørsel ; producer, Jacob Eriksen -- Europa (1991, 112 min., black and white/color, 2.39:1, stereo) / a Danish-French-German-Swedish coproduction ; produced by Gunner Obel & Nordisk Film & TV A/S [and 4 others] ; director, Lars von Trier ; producers, Peter Aalbæk Jensen, Bo Christensen ; screenplay: Lars von Terier & Niels Vørsel." ] ;
    bf:title [ a bf:Title ;
            rdfs:label "Lars von Trier's Europe trilogy :" ;
            bflc:nonSortNum "0" ;
            bf:mainTitle "Lars von Trier's Europe trilogy :" ],
        [ a bf:VariantTitle,
                <http://id.loc.gov/vocabulary/vartitletype/por> ;
            bflc:marcKey "246 30 $a Element of crime, Epidemic, Europa" ;
            bf:mainTitle "Element of crime, Epidemic, Europa" ] .

