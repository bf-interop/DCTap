        [ a bf:Note ;
            rdfs:label "Originally produced in Denmar as motion pictures in 1984, 1987, and 1991."@en ],
        [ a bf:Note ;
            rdfs:label "Title from container."@en ],
        [ a bf:Note ;
            rdfs:label "Blu-ray special features: 4K digital restoration of Europa and 3K digital restorations of The element of crime and Epidemic, all approved by director Lars von Trier, with uncompressed stereo or monaural soundtracks; audio commentaries featuring von Trier and others; Tranceformer: a portait of Lars von Trier (1997), a documentary by Stig Björkman; interview from 2005 with von Tier about Europe trilogy; making of commentaries; programs on the films featuring interviews with many of von Trier's collaborations ; two short student films by von Trier: Nocturne (1980) and Images of liberation (1982); Danish television interview with von Trier from 1991; trailers."@en ],
        [ a bf:Note ;
            rdfs:label "Includes booklet with essay by Howard Hampton (23 pages ; 17 cm.)."@en ],
        [ a bf:Note ;
            rdfs:label "Wide screen."@en ],
