        <http://id.loc.gov/vocabulary/languages/eng> ;
    bf:note [ a bf:Note,
                <http://id.loc.gov/vocabulary/mnotetype/participants> ;
            rdfs:label "Skådespelare: Toby Wallace, Michelle Lotters, Eliza Scanlen."@sv ;
            bflc:marcKey "511 0  $a Skådespelare: Toby Wallace, Michelle Lotters, Eliza Scanlen." ],
        [ a bf:Note,
                <http://id.loc.gov/vocabulary/mnotetype/lang> ;
            rdfs:label "Engelska."@sv ] ;
    bf:summary [ a bf:Summary ;
            rdfs:label "När den svårt sjuka Milla förälskar sig handlöst i den småkriminelle Moses, har hennes föräldrar lätt att hålla sig för skratt. Men i takt med att Millas kärlek växer så återkommer också hennes vilja att leva. Familjen tvingas helt enkelt inse att läget kräver en ny, uppdaterad syn på moral och förväntningar om de vill se sin dotter lycklig. Den australiensiska regissören Shannon Murphys långfilmsdebut är en smart indiepärla. ★★★★★★ \"Dess lekfulla pendlande mellan oskuld och allvar, mellan ungdom och bombastisk självständighet är helt klart berusande.\" Nora Makander, Nöjesguiden [ForlagEtt]."@sv ] ;
    bf:title [ a bf:Title ;
            rdfs:label "Babyteeth" ;
            bflc:nonSortNum "0" ;
            bf:mainTitle "Babyteeth" ] .

