    bf:summary [ a bf:Summary ;
            rdfs:label "A thought-provoking meditation on food, family, identity, immigration, and, most of all, hospitality--at the table and beyond--that's part food memoir, part appeal for more authentic decency in our daily worlds, and in the world at large -- Source other than Library of Congress."@en ] ;
