    bf:summary [ a bf:Summary ;
            rdfs:label "Under the BEPS Action 6 minimum standard on treaty shopping, members of the OECD/G20 Inclusive Framework on BEPS have committed to strengthen their tax treaties by implementing anti-abuse measures. This report reflects the outcome of the fifth peer review of the implementation of the BEPS Action 6 minimum standard on treaty shopping. It includes the aggregate results of the review and data on tax treaties concluded by the members of the OECD/G20 Inclusive Framework on BEPS as of 31 May 2022, as well as jurisdictional sections which contain detailed information for each member jurisdiction."@en ] ;
    bf:tableOfContents [ a bf:TableOfContents ;
            rdfs:label "South Africa -- Singapore -- Estonia -- Brazil -- Croatia -- Haiti -- Mauritania -- Samoa -- Indonesia -- Papua New Guinea -- Chile -- Macau (China) -- Saint Vincent and the Grenadines -- Poland -- Paraguay -- Burkina Faso -- Aruba -- Korea -- Barbados -- Viet Nam -- Argentina -- Hong Kong (China) -- Anguilla -- Japan -- Executive Summary -- The Bahamas -- Mauritius -- Malaysia -- Qatar -- Belgium -- Israel -- Togo -- Oman -- Turks and Caicos Islands -- United Arab Emirates -- Thailand -- Sierra Leone -- Jamaica -- Grenada -- Czech Republic -- Jordan -- Implementation of the minimum standard: Aggregate data and key figures -- Slovak Republic -- Georgia -- Panama -- Switzerland -- Kazakhstan -- Angola -- United States -- Saint Lucia -- United Kingdom -- Cook Islands -- Monaco -- Luxembourg -- Djibouti -- Antigua and Barbuda -- Seychelles -- Armenia -- China (People's Republic of) -- Norway -- Canada -- Saint Kitts and Nevis -- Denmark -- Cameroon -- Maldives -- Liberia -- Cayman Islands -- Colombia -- Trinidad and Tobago -- Belize -- Uruguay -- Plans for the implementation of the minimum standard and support provided to jurisdictions -- Difficulties in implementing the minimum standard -- Faroe Islands -- Background on the Action 6 minimum standard and peer review -- Peru -- Gabon -- British Virgin Islands -- Côte d'Ivoire -- Andorra -- Bermuda -- Botswana -- Italy -- Montserrat -- Malta -- Benin -- Germany -- New Zealand -- Latvia -- Saudi Arabia -- Morocco -- Tunisia -- Sri Lanka -- Albania -- Senegal -- Mexico -- Foreword -- Cabo Verde -- North Macedonia -- Greenland -- Iceland -- Greece -- Jersey -- Curaçao -- Ukraine -- Isle of Man -- Slovenia -- Pakistan -- Türkiye -- Honduras -- Mongolia -- Lithuania -- Bahrain -- Eswatini -- India -- Netherlands -- Finland -- Costa Rica -- Democratic Republic of the Congo -- Inclusive Framework members on 31 May 2022 -- Dominica -- Nigeria -- Sweden -- Portugal -- Hungary -- San Marino -- Australia -- Montenegro -- Ireland -- Namibia -- Spain -- France -- Serbia -- Bosnia-Herzegovina -- Liechtenstein -- Kenya -- Guernsey -- Bulgaria -- Conclusion and next steps -- Zambia -- Romania -- Brunei Darussalam -- Dominican Republic -- Key role of the BEPS MLI -- Congo -- Gibraltar -- Egypt -- Austria -- Recommendations." ] ;
    bf:title [ a bf:Title ;
            rdfs:label "Prevention of Tax Treaty Abuse - Fifth Peer Review Report on Treaty Shopping :" ;
            bflc:nonSortNum "0" ;
            bf:mainTitle "Prevention of Tax Treaty Abuse - Fifth Peer Review Report on Treaty Shopping :" ] .

