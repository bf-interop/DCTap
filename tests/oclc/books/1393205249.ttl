            rdfs:label "Cawson's essentials of oral pathology and oral medicine /" ;
            bflc:nonSortNum "0" ;
            bf:mainTitle "Cawson's essentials of oral pathology and oral medicine /" ],
        [ a bf:VariantTitle ;
            bflc:marcKey "246 1  $a Essentials of oral pathology and oral medicine" ;
            bf:mainTitle "Essentials of oral pathology and oral medicine" ] .

