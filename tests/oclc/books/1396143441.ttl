    bf:summary [ a bf:Summary ;
            rdfs:label "A medicines management textbook written specifically for trainee nursing associates. It breaks medicines management down into manageable chunks and guides the reader through everything from the fundamental legal and professional requirements, to medicine administration, and drug calculations skills."@en ] ;
