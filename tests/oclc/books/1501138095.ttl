            bf:role [ a bf:Role ;
                    rdfs:label "author." ] ],
        [ a bf:PrimaryContribution ;
            bflc:marcKey "100 1  $a Mortan, Kenan, $e author." ;
            bf:agent [ a bf:Person ;
                    rdfs:label "Mortan, Kenan," ] ;
            bf:role [ a bf:Role ;
                    rdfs:label "author." ] ] ;
    bf:hasInstance <https://id.oclc.org/worldcat/entity/1501138095> ;
