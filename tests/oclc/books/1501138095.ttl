<https://id.oclc.org/worldcat/entity/1501138095#work> a bf:Monograph,
        bf:Text,
        bf:Work,
        <https://id.oclc.org/worldcat/ontology/Work> ;
    bflc:governmentPubType [ a bflc:GovernmentPubType ;
            rdfs:label ""@en ] ;
    bf:content [ a bf:Content ;
            rdfs:label "text"@en ;
            bf:code "txt" ;
