        <https://id.kb.se/term/sao/Akutv%C3%A5rd>,
        <https://id.kb.se/term/sao/Psykiatri> ;
    bf:summary [ a bf:Summary ;
            rdfs:label "\"The Acute Psychiatric Emergencies (APEx) 1st edition was published in February 2020. With ongoing changes to legislation and following feedback from running the course for the past few years, the Working Group feel that a new edition is required in order to ensure that the material is up-to-date and relevant. Following discussion with the Working Group, and after presenting them with pros and cons of undertaking a revised edition vs. a new edition of the manual, they have agreed that a second edition with new typesetting and full support from the Wiley production team would be the best way forward. A second edition would revise and update the text where required\"-- Provided by publisher."@en ] ;
    bf:supplementaryContent <http://id.loc.gov/vocabulary/msupplcont/bibliography>,
        <http://id.loc.gov/vocabulary/msupplcont/index> ;
    bf:tableOfContents [ a bf:TableOfContents ;
            rdfs:label "Structured approach to acute psychiatric emergencies -- Primary unified assessment and immediate psychiatric management -- Secondary physical and psychosocial assessment -- Mental state examination -- The patient who has harmed themselves -- Organic causes for behavioural disturbances -- The acutely confused patient (including delirium) -- The intoxicated patient? -- The aggressive patient -- Special circumstances -- Legal aspects of emergency psychiatry -- Getting it right : non-technical skills -- The patient experience." ] ;
    bf:title [ a bf:Title ;
            rdfs:label "Acute psychiatric emergencies :" ;
            bflc:nonSortNum "0" ;
            bf:mainTitle "Acute psychiatric emergencies :" ] .

