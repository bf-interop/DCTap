    bf:tableOfContents [ a bf:TableOfContents ;
            rdfs:label "Introduction: \"Our ancestors the Greeks\" -- The philosopher in politics -- A biological politics? -- The endangered happiness of the city -- Citizen, city, constitution -- On the positive use of deviance -- The legislator -- The theoretical tools of the legislator -- Political matter -- Conclusion." ] ;
