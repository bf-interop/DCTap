    bf:summary [ a bf:Summary ;
            rdfs:label "On the 25th anniversary of the show \"Pee-wee's Playhouse,\" the behind-the-scenes story is being told for the first time by those who experienced it. Complete with an episode guide, biographical information about the cast and key members of the show's creative team, never-before-told anecdotes, and previously unpublished photos."@en ] ;
    bf:supplementaryContent <http://id.loc.gov/vocabulary/msupplcont/index> ;
    bf:tableOfContents [ a bf:TableOfContents ;
            rdfs:label "Introduction -- From the Groundlings up -- The pitch and the hit -- Puppetland, California -- A Christmas story -- Foreclosure -- P2K -- Appraising the playhouse -- Episode guide -- Afterword -- The Puppetland directory -- Acknowledgements -- Notes -- Back cover material." ] ;
    bf:title [ a bf:Title ;
            rdfs:label "Inside Pee-Wee's playhouse :" ;
            bflc:nonSortNum "0" ;
            bf:mainTitle "Inside Pee-Wee's playhouse :" ] .

