    bf:summary [ a bf:Summary ;
            rdfs:label "Recounts the author's travels and adventures in the United States from 1837 to 1843."@en ] ;
    bf:tableOfContents [ a bf:TableOfContents ;
            rdfs:label "Chapter I. From Bremen to New York -- Chapter II. New York to Buffalo -- Chapter III. Ohio ; Indiana ; Illinois ; Missouri -- Chapter IV. Arkansas, and \"down river\" to New Orleans -- Chapter V. Cincinnati ; A farmer's life in the woods -- Chapter VI. A farmer's life in the woods (continued) -- Chapter VII. Woodland sports ; Cane-brakes ; My examination by the school commission -- Chapter VIII. Farming at Fourche Le Fave ; A backwoods \"frolic\" ; Residence at Kelfer's farm ; Schools ; Hunting excursion -- Chapter IX. Hunting anecdotes and experiences ; Christmas ; Conwell and his reminiscences -- Chapter X. A perilous bear-hunt ; A debating society ; Panther hunt ; Disatrous events ; Death of Erskine ; Departure -- Chapter XI. A fatal brawl ; Return to Little Rock ; Summary justice ; Down South -- Chapter XII. Louisiana ; New Orleans, and home." ] ;
    bf:title [ a bf:Title ;
            rdfs:label "Wild sports in the Far West /" ;
            bflc:nonSortNum "0" ;
            bf:mainTitle "Wild sports in the Far West /" ],
        [ a bf:VariantTitle ;
            bflc:marcKey "246 13 $a Wildsports in the Far West" ;
            bf:mainTitle "Wildsports in the Far West" ] .

