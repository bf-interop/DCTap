    bf:summary [ a bf:Summary ;
            rdfs:label "\"This book provides an accessible overview of the care and management of people living with a long-term condition. Develop your skills and knowledge of the particularities of working with this group, including supporting self-care and self-management as well as providing care for those with complex needs, comorbidities and palliative care.\"-- Provided by publisher."@en ] ;
    bf:supplementaryContent <http://id.loc.gov/vocabulary/msupplcont/bibliography>,
        <http://id.loc.gov/vocabulary/msupplcont/index> ;
    bf:tableOfContents [ a bf:TableOfContents ;
            rdfs:label "Long Term Conditions Across the Lifespan -- The Nurse-Patient Relationship in Long Term Conditions -- Health Promotion in Long Term Conditions -- Self-management in Long Term Conditions -- Quality of Life and Symptom Management in Long Term Conditions -- Managing Complex Care in Long Term Conditions -- Palliative Care in Long Term Conditions." ] ;
    bf:title [ a bf:Title ;
            rdfs:label "Nursing adults with long term conditions /" ;
            bflc:nonSortNum "0" ;
            bf:mainTitle "Nursing adults with long term conditions /" ] .

