    bf:summary [ a bf:Summary ;
            rdfs:label "\"This casebook reflects the changes in family law in recent years\"-- Provided by publisher."@en ] ;
    bf:supplementaryContent <http://id.loc.gov/vocabulary/msupplcont/bibliography>,
        <http://id.loc.gov/vocabulary/msupplcont/index> ;
    bf:tableOfContents [ a bf:TableOfContents ;
            rdfs:label "Justifying the legal treatment of family and marriage own way -- Access to relationships -- Regulating ongoing relationships -- Dissolution and divorce -- The economics of dissolution -- Parents, children, and the state -- The child welfare system -- Adoption -- Who is a parent -- Custody and visitation -- Family support." ] ;
    bf:title [ a bf:Title ;
            rdfs:label "Family law in a changing America /" ;
            bflc:nonSortNum "0" ;
            bf:mainTitle "Family law in a changing America /" ] .

