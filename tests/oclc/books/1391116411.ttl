    bf:note [ a bf:Note ;
            rdfs:label "\"21st anniversary conference of the Society of Bookbinders Manchester--June 1995\"--Cover."@en ],
        [ a bf:Note ;
            rdfs:label "\"Machine setting in 12 pt Monotype Caslon by Peter 'Captain Caslon' Sanderson of Whittington Press and hand set in Verona and printed on his Arab treadle press by Graham Moss at Incline Press. This edition is in two parts: 125 numbered copies were printed on handmade paper from Griffin Mill for the mailing list of Incline Press ... Oldham ... A further impression without limit has been made on acid free paper for the use of the bindery at PAPERSAFE ...\"--Colophon."@en ],
        [ a bf:Note ;
            rdfs:label "Publisher's device at colophon and on front wrapper."@en ],
        [ a bf:Note ;
            rdfs:label "\"An Incline Press keepsake\"--Cover."@en ],
        [ a bf:Note ;
            rdfs:label "Extracted from: A narrow street. London : Cresset Press, 1942."@en ],
        [ a bf:Note ;
            rdfs:label "Binding: printed paper wrapper."@en ] ;
