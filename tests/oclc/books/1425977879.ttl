    bf:summary [ a bf:Summary ;
            rdfs:label "\"This handbook provides a detailed explanation of \"how a bill becomes a law\" in the California Legislature. It provides important information for those wanting to understand the legislative process in the State of California. The book's contents cover drafting bills as a concept to final action by the Governor, and all of the necessary steps in the California legislative process.\"-- Taken from back cover."@en ] ;
    bf:supplementaryContent <http://id.loc.gov/vocabulary/msupplcont/index> ;
    bf:tableOfContents [ a bf:TableOfContents ;
            rdfs:label "Overview of the Legislature -- Legislature' s constitutional provisions -- Basics of the legislative process -- Additional insights into the legislative process -- Key differences between the Assembly and Senate -- Legislative calendar -- Legislative deadlines -- Referral of bills -- Legislative committee system -- Types of legislative committees -- Legislative committee rules -- Legislative committee staff -- Legislative committee hearings -- Suspense file process for fiscal bills -- Legislative floor procedures -- Methods of floor voting -- Vote requirements for bills -- Reconsideration of bills -- Phrases you might hear on the legislative floors -- Differences in the legislative floor operations -- Items on concurrence -- Addressing some end-of-session items -- Overview of the legislative publications -- Legislative lingo -- A primer on special sessions -- Practical items for special sessions -- Fiscal emergency special sessions -- Governor's timeline for acting on bills -- Influences on shaping legislation -- Legislative process obstacles -- Dissecting bills in the Legislature -- Frequently asked questions about the legislative process -- Index of topics." ] ;
    bf:title [ a bf:Title ;
            rdfs:label "A practical guide to the California legislative process /" ;
            bflc:nonSortNum "2" ;
            bf:mainTitle "A practical guide to the California legislative process /" ] .

