    bf:note [ a bf:Note ;
            rdfs:label "GenderFail Anthology of Queer Typography Vol.1 is a the first volume in a series of publications, workshops and programs exploring queer and trans exploration and experiments in typography. This first volume focuses on GenderFails ongoing typographic series of fonts created from the hand letters of protest signs from historical and contemporary acts of resistance centering the voices of queer, trans, black and other marginalized voices. This first volume also features a reprinting of Paul Soulellis's What is Queer Typography? that acts as both the forward to this anthology but the series in general."@en ],
        [ a bf:Note ;
            rdfs:label "\"Edited and designed by Be Oakley; What is Queer Typography? by Paul Soulellis; Protest Sign Typesets by Be Oakley\"--Colophon."@en ],
        [ a bf:Note,
                <http://id.loc.gov/vocabulary/mnotetype/physical> ;
            rdfs:label "illustartions,"@en ],
        [ a bf:Note,
                <http://id.loc.gov/vocabulary/mnotetype/accmat> ;
            rdfs:label "4 photocards"@en ] ;
