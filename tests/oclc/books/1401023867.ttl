    bf:summary [ a bf:Summary ;
            rdfs:label "\"In this comprehensive and unique handbook, you will find information on modern oncology. Using high-quality illustrations and graphics, this standard work vividly demonstrates - the basics of tumor development, - clinical diagnostics and therapy, - the special oncology of all tumor forms of dogs and cats. Literature references for more in-depth literature study are included. Nutrition of tumor patients, palliative care, paraneoplastic syndromes, and reconstructive surgery are also considered. Thus, this book provides decision support and precise guidance for all-around successful tumor management in the small animal patient\"-- Provided by publisher"@en ] ;
    bf:supplementaryContent <http://id.loc.gov/vocabulary/msupplcont/bibliography> ;
    bf:tableOfContents [ a bf:TableOfContents ;
            rdfs:label "Etiology and pathology of cancer -- Tumorigenesis due to viruses -- Paraneoplastic syndromes -- Clinical diagnostics -- Imaging techniques in oncology -- Tissue diagnosis -- Oncological surgery -- Cytostatic therapy -- Basics of radiotherapy -- Principles of immunotherapy -- Tyrosine kinase inhibitors, cyclooxygenase inhibitors, metronomic chemotherapy, electrochemotherapy, and retinoids. -- Cryosurgery -- Photodynamic therapy -- Hyperthermia -- Supportive therapy -- Tumors of the skin -- Mammary tumors -- Tumors of the gastrointestinal tract -- Tumors of the respiratory tract -- Tumors of the parenchymatous organs -- Tumors of the urinary organs -- Tumors of the genitals -- Cardiac and mesenteric tumors -- Mesothelioma -- Tumors of the skeleton -- Tumors of the toes -- Tumors of endocrine organs -- Tumors of the nervous system -- Neoplasms of the eye -- Tumors of the auditory canal and middle ear -- Tumors of hematopoietic and lymphoid tissues" ] ;
    bf:title [ a bf:Title ;
            rdfs:label "Small animal oncology" ;
            bflc:nonSortNum "0" ;
            bf:mainTitle "Small animal oncology" ] .

