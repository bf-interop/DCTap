    bf:note [ a bf:Note,
                <http://id.loc.gov/vocabulary/mnotetype/descsource> ;
            rdfs:label "Description based on: first issue; title from front cover."@en ],
        [ a bf:Note,
                <http://id.loc.gov/vocabulary/mnotetype/physical> ;
            rdfs:label "maps ;"@en ],
        [ a bf:Note,
                <http://id.loc.gov/vocabulary/mnotetype/descsource> ;
            rdfs:label "Latest issue consulted: 2023."@en ],
        [ a bf:Note ;
            rdfs:label "\"Each winery receives a review divided in three sections : the first one is dedicated to the people who live and work at the winery, the second to the vineyards and the way they're farmed, and the third to the finest wines currently available on the market. The very best wines are awarded Top Wine accolade. Among these we have the Slow Wines -- which beyond their outstanding sensory quality are of particular interest for their sense of place, environmental sustainability or historical value -- and the Everyday Wines, representing excellent value at prices within $30. The most interesting wineries on the other hand are awarded the Snail, for the way they interpret Slow Food values (sensory perceptions, territory, environment, identity) while offering good value for money ; the Bottle to wineries whose wines are of outstanding sensory quality throughout the range ; the Coin to those estates offering excellent value for money.\"--taken from 2022 guide back cover."@en ],
        [ a bf:Note,
                <http://id.loc.gov/vocabulary/mnotetype/number> ;
            rdfs:label "Began with 2021 guide."@en ],
        [ a bf:Note ;
            rdfs:label "Editor-in-chief: Giancarlo Gariglio."@en ] ;
