    bf:summary [ a bf:Summary ;
            rdfs:label "DVD includes six short videos about bells in Europe and West Africa. The first two videos show bell-dressed carnival dances in Sardinia (Italy) and Skyros (Greece). The third piece shows car horn and hand bell musical performances in Accra by the La Drivers Union Por Por Group. The fourth piece features Nil Otoo Annan performing his Bufo Variations on an instrument of his own invention, the gangofone, a rack of gangokui double bells. The fifth piece, made in collaboration with blacksmith Tom Joyce, documents the complete manufacture and tuning of gangokui double bells in Yohonou, a renown community of blacksmiths in Togo. The final piece features master blacksmith of Northern Togo who makes the ekpande bell, central to the Waa initiation performances of Kabre youth."@en ] ;
    bf:tableOfContents [ a bf:TableOfContents ;
            rdfs:label "Mamuthones and issohadores of Mamoida, Sardinia (10:19) -- Carnival of Skyros (11:38) -- Por Por horns and double bells in Accra (12:33) -- Toad's and bells of Accra (13:13) -- Making double bells in Yohonou (16:03) -- Striking iron, sounding initiation (20:45)." ] ;
    bf:title [ a bf:Title ;
            rdfs:label "The time of bells. 5 /" ;
            bflc:nonSortNum "4" ;
            bf:mainTitle "The time of bells." ;
            bf:partNumber "5 /" ] .

