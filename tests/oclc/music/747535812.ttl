            bf:source <http://id.loc.gov/authorities/subjects> ;
            madsrdf:componentList ( [ a bf:Topic ;
                        rdfs:label "Blues (Music)" ;
                        bf:identifiedBy [ a bf:Local ;
                                bf:assigner [ a bf:Organization ;
                                        bf:code "OCoLC" ] ;
                                rdf:value "oca8839505" ] ] [ a bf:Temporal ;
                        rdfs:label "2011-2020." ;
                        bf:identifiedBy [ a bf:Local ;
                                bf:assigner [ a bf:Organization ;
                                        bf:code "OCoLC" ] ;
                                rdf:value "oca8839505" ] ] ) ] ;
    bf:summary [ a bf:Summary ;
            rdfs:label "This album returns Johnny Winter to his roots by paying homage to the iconic blues heroes whose pioneering music influenced Winter's own signature sound. Roots is the follow up to his Grammy-nominated I'm a Blues Man, and includes a host of special guests who join Winter in trading licks to honor his idols."@en ] ;
    bf:tableOfContents [ a bf:TableOfContents ;
            rdfs:label "T-bone shuffle (featuring Sonny Landreth) (4:54) -- Further on up the road (featuring Jimmy Vivino) (4:18) -- Done somebody wrong (featuring Warren Haynes) (4:47) -- Got my mojo workin' (featuring Frank Latorre) (5:10) -- Last night (featuring John Popper) (5:47) -- Maybellene (featuring Vince Gill) (2:49) -- Bright lights, big city (featuring Susan Tedeschi) (4:28) -- Honky tonk (featuring Edgar Winter) (3:43) -- Dust my broom (featuring Derek Trucks) (6:04) -- Short fat fannie (featuring Paul Nelson) (4:07) -- Come back baby (featuring John Medeski) (6:28)." ] ;
    bf:title [ a bf:Title ;
            rdfs:label "Roots /" ;
            bflc:nonSortNum "0" ;
            bf:mainTitle "Roots /" ] .

