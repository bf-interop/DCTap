        <https://id.oclc.org/worldcat/entity/E39PBJjhFyhTBdYgGbRpV6YwYP>,
        <https://id.oclc.org/worldcat/entity/E39Qhp4vBbvhYqGG9XpyhcYtpX> ;
    bf:summary [ a bf:Summary ;
            rdfs:label "On March 16, 1968, the United States Army killed over 500 unarmed civilians in the hamlet of Mỹ Lai, Vietnam. This definitive recording of the new opera Mỹ Lai recounts the visceral, phantasmal feelings of grief and horror experienced by US helicopter pilot Hugh Thompson on that day and in the haunting memories over the nearly four decades since."@en ] ;
    bf:supplementaryContent <http://id.loc.gov/vocabulary/msupplcont/historicalinfo>,
        <http://id.loc.gov/vocabulary/msupplcont/libretto>,
        <http://id.loc.gov/vocabulary/msupplcont/techmusic> ;
    bf:tableOfContents [ a bf:TableOfContents ;
            rdfs:label "Mỹ Lai lullaby (7:58) -- First landing: flight (9:36) -- First landing: descent (7:04) -- First landing: the ditch (14:16) -- Second landing: hovering (8:26) -- Second landing: bunker (12:31) -- Third landing: postcard (5:16) -- Third landing: fishing (5:45)." ] ;
    bf:title [ a bf:Title ;
            rdfs:label "Mỹ Lai /" ;
            bflc:nonSortNum "0" ;
            bf:mainTitle "Mỹ Lai /" ] .

