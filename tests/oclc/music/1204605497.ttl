    bf:supplementaryContent <http://id.loc.gov/vocabulary/msupplcont/libretto> ;
    bf:tableOfContents [ a bf:TableOfContents ;
            rdfs:label "Disc 1. Future nostalgia -- Don't start now -- Cool -- Physical -- Levitating -- Pretty please -- Hallucinate -- Love again -- Break my heart -- Good in bed (explicit) -- Boys will be boys -- Levitating (feat. DaBaby)." ],
        [ a bf:TableOfContents ;
            rdfs:label "Disc 2 (with the Blessed Madonna). Future nostalgia (Joe Goddard remix) -- Cool (Jayda G remix) -- Good in bed (Zach Witness & Gen Hoshino remixes) -- Pretty please (Midland refix) -- Pretty please (Masters at work remix) -- Boys will be boys (Zach Witness remix) -- Love again (Horse meat disco remix) -- Break my heart ; Cosmic girl (Dimitri from Paris edit) -- Levitating (the Blessed Madonna remix) (feat. Madonna and Missy Elliott) -- Hallucinate (Mr. FIngers deep stripped mix) -- Hallucinate (Paul Woolford remix) -- Love is religion (the Blessed Madonna remix) -- Don't start now (Yaeji remix) -- Physical (Mark Ronson remix) (feat. Gwen Stefani) -- Kiss and make up (remix) -- That kind of woman (Jacques Lu Cont remix) -- Break my heart (Moodymann remix)." ] ;
    bf:title [ a bf:VariantTitle ;
