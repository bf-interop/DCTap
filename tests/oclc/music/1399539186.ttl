        [ a bf:TableOfContents ;
            rdfs:label "CD1, Opening set. Intro -- Honey, I need -- Don't bring me down -- Buzz the jerk -- Mama, keep your big mouth shut -- Get the picture? -- The same sun -- Alexander ; Defecting grey -- Big boss man -- Midnight to six man -- Mr. Evasion." ],
        [ a bf:TableOfContents ;
            rdfs:label "CD1, S.F. Sorrow set. Intro -- Scene one -- S.F. Sorrow is born -- She says good morning -- Baron Saturday -- Trust -- I see you -- Cries from the midnight circus." ],
        [ a bf:TableOfContents ;
            rdfs:label "CD2, End set. Intro -- Can't be satisfied -- Come in my kitchen -- Baby, please don't go -- I can tell -- You can't judge a book by its cover -- Come see me -- Mona -- L.S.D. ; Old man going -- Encore intro -- Rosalyn -- Loneliest person -- Phil's final words." ] ;
