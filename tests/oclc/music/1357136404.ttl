    bf:tableOfContents [ a bf:TableOfContents ;
            rdfs:label "The toy trumpet (3:30) -- Hillbilly from Tenth Avenue (2:48) -- My old Kentucky home (2:06) -- Any old time (3:09) -- Powerhouse (3:14) -- Take my word (2:52) -- Azure (3:28) -- The call of the freaks (2:48) -- The old apple tree (2:46) -- Lost in the shuffle (2:39) -- If dreams come true (3:02) -- Moonlight of the Sunset Trail (2:52) -- More than ever (2:44) -- I'll never let you cry (1:57) -- In the shade of the new apple tree (2:36) -- It's wonderful (3:00) -- Blue fantasy (2:59) -- Love's old sweet song (2:55) -- Indian love call (2:54) -- Meade Lux special (3:28) -- Sweet and low (1:35)." ] ;
