    bf:summary [ a bf:Summary ;
            rdfs:label "Planet B is the new project and title of the first of four albums that sees Danish composer and bassist open up big questions for everyone. Together with the fearless young British saxophonist Josh Arcoleo and adventurous French drummer Marc Michel, Jasper Høiby is shaping adventurous new music to prise open the narrow framework of political debate. Planet B, the project title and title of the first album, is a mix of deep, evocative, thought-provoking voice samples, loops, held together with the open, majestic interplay of three deeply intuitive and creative musicians. Each of the albums will focus on four global topics of vital importance-- Humanity, Climate Change, Artificial Intelligence and Monetary Reform."@en ] ;
    bf:tableOfContents [ a bf:TableOfContents ;
            rdfs:label "Story of self (4:10) -- Reimagine (5:43) -- Consciousness (5:30) -- Interconnectedness (4:56) -- Never forgotten (5:19) -- The dinosaur (2:20) -- We didn't earn the sun (3:59) -- Life is a gift (7:32) -- Never give up (3:30) -- Reimagine (outro) (2:23)." ] ;
    bf:title [ a bf:Title ;
            rdfs:label "Planet B /" ;
            bflc:nonSortNum "0" ;
            bf:mainTitle "Planet B /" ] .

