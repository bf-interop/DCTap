    bf:supplementaryContent <http://id.loc.gov/vocabulary/msupplcont/historicalinfo> ;
    bf:tableOfContents [ a bf:TableOfContents ;
            rdfs:label "Disc 1. Living in a great big way (Bill \"Bojangles\" Robinson, Thomas \"Fats\" Waller, & Jeni Le Gon) -- Congo fever (Jungle fever) (the Mills Brothers) -- Let that be a lesson to you (Johnnie \"Scat\" Davis, Frances Langford, & Benny Goodman & his orchestra) -- I've got a heartful of music (the Benny Goodman Quartet) -- You're an education (the Three Symphonettes with Freddie Rich & his orchestra) -- All God's chillun got rhythm (Ivie Anderson, Benny & the Chrinoline Choir, with Duke Ellington & his orchestra) -- Jeepers creepers (Louis Armstrong) -- Nightmare ; Traffic jam (Artie Shaw & his orchestra) -- Blues in the night (Jimmie Lunceford & his orchestra) -- You've got to know how to dance (Six Hits and a Miss with the Warner Bros. studio orchestra) -- Buds won't bud (Ethel Waters) -- Medley: Things ain't what they used to be/Going up (Duke Ellington & his orchestra) -- Shine (Buck & Bubbles and the Hall Johnson Choir) -- Mrs. Whiffen (Mel Tormé, Marcy McGuire, & Ivy Scott) -- One o'clock jump (Jimmy Dorsey & his orchestra) -- Body and soul (the Hazel Scott Trio) -- Toot suite (Harry James & his orchestra) -- Hong Kong blues ; Baltimore oriole (Hoagy Carmichael) -- Please don't say no (the King Sisters) -- Jammin' the blues (Lester Young & company) -- On the sunny side of the street (Marie Bryant, Lester Young, & company) -- It's you or no one (Doris Day with the Page Cavanaugh Trio) -- You do something to me ; I'll get by (Lena Horne)." ],
        [ a bf:TableOfContents ;
            rdfs:label "Disc 2. Medley: Do, do, do/Bidin' my time/I've got a crush on you/Love is here to stay (Benny Carter & his orchestra) -- Ain't misbehavin' (Louis Armstrong & his All-Stars with Jack Teagarden) -- Hold me close to you (Billy Eckstine) -- Taking a chance on love (Dorothy Dandridge) -- My flaming heart (Nat \"King\" Cole) -- Now you has jazz ; I love you, Samantha (Bing Crosby & Louis Armstrong) -- I got it bad and that ain't good (Julie Wilson with Ray Anthony & his orchestra) -- Improvisation (Source #1) ; Red drum blues ; Improvisation (Source #2) (André Previn Trio) -- Coffee time (Carmen McCrae with the André Previn Trio) -- Spaghetti fantasy ; Alarm clock (Gerry Mulligan & company) -- Should I? (André Previn Trio) -- Things are looking down ; Bread and wine (Gerry Mulligan & company) -- God bless the child (Pearl Bailey) -- Don't blame me (Leslie Uggams) -- Sunday in New York (Mel Tormé) -- The girl from Ipanema (Stan Getz & Astrud Gilberto) -- Skol sister ; Goof proof ; Lottie (Count Basie & his octet) -- I got rhythm (Louis Armstrong)." ] ;
    bf:title [ a bf:VariantTitle ;
            bflc:marcKey "246 3  $a Hollywood swing and jazz" ;
            bf:mainTitle "Hollywood swing and jazz" ],
        [ a bf:Title ;
            rdfs:label "Hollywood swing & jazz :" ;
            bflc:nonSortNum "0" ;
            bf:mainTitle "Hollywood swing & jazz :" ] .

