    bf:summary [ a bf:Summary ;
            rdfs:label "The James Hunter Six are back with another sublime offering of no-nonsense rhythm and blues. Recorded and produced by Bosco Mann, the album is a shining example of how a master song-smith can continually draw fresh water from a bottomless well. In addition to the uptempo, swinging R & B that has put JH6 on the map."@en ] ;
    bf:tableOfContents [ a bf:TableOfContents ;
            rdfs:label "I can change your mind -- Who's fooling who -- Till I hear it from you -- Never -- Missing in action -- Nick of time -- Brother or other -- Ain't goin' up in one of those things -- Take it as you find it -- Can't help myself -- How 'bout now -- Paradise for one -- He's your could've been." ] ;
    bf:title [ a bf:Title ;
            rdfs:label "Nick of time /" ;
            bflc:nonSortNum "0" ;
            bf:mainTitle "Nick of time /" ] .

