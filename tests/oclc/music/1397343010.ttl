    bf:note [ a bf:Note ;
            rdfs:label "All tracks previously unreleased."@en ],
        [ a bf:Note ;
            rdfs:label "Consists of two 12-inch 45 rpm LPs (May 1965 demos and alternate version), a 7-inch 45 rpm EP (1958 rehearsal and 1963-1964 home recordings), and a CD containing complete audio from the LPs and EP."@en ],
        [ a bf:Note ;
            rdfs:label "Includes 28-page booklet featuring lyrics, archival photos, and liner notes by Greil Marcus, Don Fleming, and Jason Stern; includes archival reproduction of letter written by Lou Reed to Delmore Schwartz, circa 1964."@en ],
        [ a bf:Note ;
            rdfs:label "Title from disc label."@en ] ;
