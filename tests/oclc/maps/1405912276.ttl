    bf:note [ a bf:Note ;
            rdfs:label "\"Cartographers: Ute J. Dymon, Terry N. Sylvia, University of Massachusetts at Amherst.\""@en ],
        [ a bf:Note ;
            rdfs:label "Map showing the distribution of multi-user computer systems installed in Western Europe as of January 1, 1986 by administrative division. Sample data for the map was compiled by IDC using over 50,000 computer systems installed in the region. Includes a color-coded legend classifying computer systems as small, medium, or large based on system cost, in U.S. dollars, and total number of potential users. Each administrative district on the recto of the map is numbered, with a corresponding key on the map's verso."@en ],
        [ a bf:Note,
                <http://id.loc.gov/vocabulary/mnotetype/physical> ;
            rdfs:label "color ;"@en ],
        [ a bf:Note ;
            rdfs:label "Title from caption."@en ] ;
