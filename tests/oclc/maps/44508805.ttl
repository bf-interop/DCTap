        [ a bf:Note ;
            rdfs:label "Includes text, 5 col. ancillary maps, 2 tables titled \"Selected Quaternary faults in Arizona\" and \"Notable historical earthquakes in or near Arizona\" and 2 block diagrams."@en ],
        [ a bf:Note ;
            rdfs:label "Ancillary maps and block diagrams, with text: Earthquakes and faulting -- Regional faults and large earthquakes -- Ground shaking and earthquake damage in Arizona (1877-1999) -- Earthquake hazards in the Yuma area -- Earthquakes and faults in the Flagstaff-Grand Canyon area -- Earthquake hazard summary."@en ],
        [ a bf:Note ;
            rdfs:label "Shows quaternary faults, earthquake locations by magnitude, and earthquake locations by \"felt intensity.\""@en ],
        [ a bf:Note ;
            rdfs:label "Relief shown by shading."@en ] ;
